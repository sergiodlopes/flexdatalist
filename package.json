{
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter flexdatalist build",
    "build:vue": "pnpm --filter flexdatalist-vue build",
    "build:react": "pnpm --filter flexdatalist-react build",
    "build:svelte": "pnpm --filter flexdatalist-svelte build"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
