{
  "name": "flexdatalist",
  "description": "Standalone autocomplete/datalist input — no dependencies",
  "version": "3.0.1",
  "type": "module",
  "main": "dist/flexdatalist.umd.js",
  "module": "dist/flexdatalist.es.js",
  "exports": {
    ".": {
      "import": "./dist/flexdatalist.es.js",
      "require": "./dist/flexdatalist.umd.js"
    },
    "./css": "./dist/flexdatalist.css",
    "./standalone": "./src/flexdatalist.js",
    "./standalone/css": "./src/flexdatalist.css"
  },
  "files": [
    "dist",
    "src/flexdatalist.js",
    "src/flexdatalist.css"
  ],
  "style": "dist/flexdatalist.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/sergiodlopes/flexdatalist.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/sergiodlopes/flexdatalist/issues"
  },
  "keywords": [
    "autocomplete",
    "datalist",
    "typeahead",
    "tags",
    "input",
    "vanilla-js"
  ],
  "author": "Sérgio Dinis Lopes",
  "license": "MIT",
  "homepage": "https://github.com/sergiodlopes/flexdatalist",
  "scripts": {
    "build": "vite build"
  },
  "devDependencies": {
    "vite": "^6"
  }
}
